# MongoDB Atlas connection string
# Get this from: MongoDB Atlas → Database → Connect → Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/leadflow?retryWrites=true&w=majority

# Server port (default: 3001)
PORT=3001

# Optional values for `npm run create-user`
# USER_NAME=Admin User
# USER_EMAIL=admin@example.com
# USER_PASSWORD=change-me
